{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-patterns.dev/schemas/research.schema.json",
  "title": "PatternResearch",
  "description": "Shared shape for the files under data/patterns/<id>/research/*.json. Each file holds one critical research dimension on that pattern.",
  "oneOf": [
    {
      "title": "OpinionatedResearch",
      "description": "critique.json, counter-arguments.json — a stance plus a list of bullet points.",
      "type": "object",
      "additionalProperties": false,
      "required": ["stance", "summary", "points"],
      "properties": {
        "stance":  { "type": "string", "enum": ["supports", "challenges", "mixed", "unknown"] },
        "summary": { "type": "string" },
        "points":  {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text":      { "type": "string" },
              "severity":  { "type": "string", "enum": ["info", "note", "warning", "blocker"] },
              "source_id": { "type": "string", "description": "Optional reference to data/sources/<id>/." }
            }
          }
        }
      }
    },
    {
      "title": "ItemList",
      "description": "tools.json, extensions.json, sources.json — a summary plus a list of cross-references.",
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "items"],
      "properties": {
        "summary": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text":       { "type": "string" },
              "ref_type":   { "type": "string", "enum": ["tool", "pattern", "source", "concept", "external"] },
              "ref_id":     { "type": "string", "description": "Id within the chosen ref_type's folder." },
              "url":        { "type": "string", "description": "External URL when ref_type = external." }
            }
          }
        }
      }
    }
  ]
}
