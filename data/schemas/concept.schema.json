{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-patterns.dev/schemas/concept.schema.json",
  "title": "Concept",
  "description": "Short vocabulary entry. Lives at data/concepts/<id>/concept.json. Optional long-form article in article.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "term", "short", "patterns"],
  "properties": {
    "id":       { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "term":     { "type": "string" },
    "short":    { "type": "string" },
    "patterns": { "type": "array", "items": { "type": "string" } }
  }
}
