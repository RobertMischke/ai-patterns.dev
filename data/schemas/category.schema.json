{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-patterns.dev/schemas/category.schema.json",
  "title": "Category",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "num", "name", "tagline", "blurb"],
  "properties": {
    "id":      { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "num":     { "type": "string" },
    "color":   { "type": "string", "description": "CSS color/variable used for accent." },
    "name":    { "type": "string" },
    "tagline": { "type": "string" },
    "blurb":   { "type": "string" }
  }
}
